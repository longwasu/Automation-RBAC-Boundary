{
    "adminRole": "all_access",
    "tiers": [
        "nst_soc_manager",
        "nst_soc_analyst",
        "nst_soc_viewer",
        "nst_compliance_auditor",
        "nst_threat_hunting_ro"
    ],
    "baseline": {
        "health": "r",
        "self": "rw",
        "agents-summary": "r"
    },
    "groups": [
        {
            "group": "self",
            "paths": "/security/users/me, /security/user/authenticate"
        },
        {
            "group": "agents-summary",
            "paths": "/agents/summary"
        },
        {
            "group": "agent-files",
            "paths": "/retrieved-files, /agents/{id}/retrieved-files"
        },
        {
            "group": "agent-inventory",
            "paths": "/syscheck, /syscollector, /sca, /rootcheck"
        },
        {
            "group": "ar-command",
            "paths": "/ar, /ar/catalog, /agents/{id}/ar[/{action}]"
        },
        {
            "group": "agents",
            "paths": "/agents"
        },
        {
            "group": "groups",
            "paths": "/groups"
        },
        {
            "group": "ruleset",
            "paths": "/rules, /decoders, /lists"
        },
        {
            "group": "active-response",
            "paths": "/active-response"
        },
        {
            "group": "manager-admin",
            "paths": "/manager, /cluster"
        },
        {
            "group": "tasks",
            "paths": "/tasks"
        },
        {
            "group": "rbac",
            "paths": "/security/*"
        },
        {
            "group": "health",
            "paths": "/, /ping"
        }
    ],
    "caps": {
        "nst_soc_manager": {
            "agents": "rw",
            "agent-inventory": "r",
            "agent-files": "rw",
            "groups": "rw",
            "ruleset": "rw",
            "manager-admin": "rw",
            "active-response": "rw",
            "tasks": "r"
        },
        "nst_soc_analyst": {
            "agents": "r",
            "agent-inventory": "r",
            "agent-files": "r",
            "groups": "r",
            "ruleset": "r",
            "manager-admin": "r",
            "active-response": "w",
            "tasks": "r"
        },
        "nst_soc_viewer": {
            "agents": "r",
            "agent-inventory": "r",
            "groups": "r",
            "ruleset": "r"
        },
        "nst_compliance_auditor": {},
        "nst_threat_hunting_ro": {}
    },
    "ar": {
        "adminRole": "all_access",
        "actionRisk": {
            "isolate": "high",
            "unisolate": "change",
            "ping": "read",
            "list-processes": "read",
            "list-connections": "read",
            "getfile": "change",
            "kill-process": "high",
            "quarantine-file": "high",
            "restore-file": "change",
            "run-command": "exec"
        },
        "roleRisk": {
            "nst_soc_manager": [
                "read",
                "change",
                "high"
            ],
            "nst_soc_analyst": [
                "read",
                "change",
                "high"
            ],
            "nst_soc_viewer": [
                "read"
            ]
        },
        "taskDeleteRoles": [
            "nst_soc_manager"
        ]
    }
}